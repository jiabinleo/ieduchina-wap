<!DOCTYPE html>
<html>

<head>
	<title>
		<%= process.env.appName %>
	</title>
	<%= require('@layouts/meta.ejs')()%>
		<%= require('@layouts/rem.ejs')() %>
			<%= require('@layouts/logincss.ejs')()%>
</head>

<body>
	<header class="header">
		<a class="back"></a>
		<h2>发布微头条</h2>
		<a class="cancel">取消</a>
	</header>
	<section class="section">
		<div class="publish-image">
			<div class="textarea" contenteditable="true">
				这个[笑脸]是一个笑脸
			</div>
			<div class="weui-cells weui-cells_form" id="uploaders">
				<div class="weui-cell">
					<div class="weui-cell__bd">
						<div class="weui-uploader">
							<div class="weui-uploader__hd">
								<p class="weui-uploader__title">图片上传</p>
								<div class="weui-uploader__info"><span id="uploadCount">0</span>/9</div>
							</div>
							<div class="weui-uploader__bd">
								<ul class="weui-uploader__files" id="uploaderFiles"></ul>
								<div class="weui-uploader__input-box">
									<input id="uploaderInput" class="weui-uploader__input" type="file" accept="image/*"
										capture="camera" multiple="" />
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="checkbox">
				<label>
					<input type="checkbox">保存到草稿箱
				</label>
			</div>
			<div class="btn">
				<button>发布</button>
			</div>
		</div>
		div class="publish-video-popup">
			<img src="<%=require('@images/close.png')%>" alt="" class="close">
			<img class="status" src="<%=require('@images/err.png')%>" alt="">
			<h3>上传失败！</h3>
			<p>视频文件已超过60秒,请重新上传视频文件。</p>
		</div>
	</section>
	<%= require('@layouts/loginjs.ejs')()%>
		<script defer='defer'>
			var str = $(".textarea").text().replace('[笑脸]', '<img class="status" src="<%=require('@images/err.png')%>" alt="">')
			// setTimeout(()=>{
			$(".textarea").html(str)
		// },3000)
		</script>
</body>

</html>