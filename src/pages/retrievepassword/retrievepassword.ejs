<!DOCTYPE html>
<html lang="zh">
<%= require('@layouts/head.ejs')() %>
<body>
    <header class="headernew">
        <a class="back"></a>
        <h2>找回密码</h2>
    </header>
    <section class="section">
        <div class="retrieve">
            <form action="">
                <div class="input user">
                    <input type="text" placeholder="请输入手机号码" name="phone" nullmsg="请输入手机号码" errormsg="手机号格式不正确" datatype="phone">
                </div>
                <div class="input verify">
                    <input type="text" placeholder="请输入验证码" name="verify" nullmsg="请输入验证码">
                    <input type="button" class="getCode" value="获取验证码">
                </div>
                <div class="input psd">
                    <input type="password" placeholder="请输入新密码" name="password" nullmsg="请输入新密码">
                </div>
                <div class="input psd">
                    <input type="password" placeholder="请再次输入密码" name="password" nullmsg="请再次输入密码">
                </div>
                <button class="submit bt2" success="提交成功" error="提交失败">提交</button>
            </form>
        </div>
    </section>
<%= require('@layouts/footer.ejs')({footer:false})%>
</body>

</html>