<!DOCTYPE html>
<html>
	<head>
		<title><%= process.env.appName %></title>
		<%= require('@layouts/meta.ejs')()%>
		<%= require('@layouts/rem.ejs')() %>
		<%= require('@layouts/logincss.ejs')()%>
	</head>

	<body>
		<header class="header">
			<a class="back"></a>
			<h2>个人中心</h2>
		</header>
		<section class="section">
			<div class="personal-center-banner" style="background-image: url(https://picsum.photos/id/838/750/470);">
				<div class="personal-center-banner-mask">
					<a href="./dynamicpage.html">
						<img class="user-avatar" src="https://picsum.photos/id/338/120/120">
						<h3>波斯的猫咪</h3>
