							</a>
						</li>
						<li>
							<a>
								<span>36</span>
								<p>粉丝</p>
							</a>
						</li>
						<li>
							<a href="./followlist.html">
								<span>36</span>
								<p>关注</p>
							</a>
						</li>
					</ul>
					<a class="btn" href="./personal.html">个人资料</a>
				</div>
			</div>
			<div class="personal-center-menu">
				<ul>
					<% var list=[
						{
							name:'创作中心',
							link:'./creativecenter.html'
						},
						{
							name:'消息通知',
							link:'javascript:'
