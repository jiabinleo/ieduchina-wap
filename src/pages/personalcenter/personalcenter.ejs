						{
							name:'草稿箱',
							link:'./drafts.html'
						},
						{
							name:'收藏',
							link:'javascript:'
						},
						{
							name:'国际教育号',
							link:'javascript:'
						},
						{
							name:'预约',
							link:'javascript:'
						},
						{
							name:'评论',
							link:'javascript:'
						},
						{
							name:'关注',
							link:'./followlist.html'
						}
					] %>
					<% list.forEach(function(lis){%>
					<li>
						<a href="<%=lis.link%>">
							<i></i>
							<p><%=lis.name%></p>
						</a>
					</li>
					<%})%>
				</ul>
			</div>
		</section>
		<%= require('@layouts/loginjs.ejs')()%>
