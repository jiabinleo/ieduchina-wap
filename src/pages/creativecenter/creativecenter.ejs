<!DOCTYPE html>
<html>
	<head>
		<title><%= process.env.appName %></title>
		<%= require('@layouts/meta.ejs')()%>
		<%= require('@layouts/rem.ejs')() %>
		<%= require('@layouts/logincss.ejs')()%>
	</head>

	<body>
		<header class="header">
			<a class="back"></a>
			<h2>创作中心</h2>
		</header>
		<section class="section">
			<div class="creative-center-banner" style="background-image: url(https://picsum.photos/id/838/750/470);">
				<div class="creative-center-banner-mask">
					<div class="top">
						<a href="./dynamicpage.html">
							<img class="user-avatar" src="https://picsum.photos/id/338/120/120">
						</a>
						<h3>波斯的猫咪</h3>
					</div>
					<ul class="statistical">
						<li>
							<a>
								<span>36</span>
								<p>动态</p>
							</a>
						</li>
						<li>
							<a>
								<span>36</span>
								<p>粉丝</p>
							</a>
						</li>
						<li>
							<a>
								<span>36</span>
								<p>关注</p>
							</a>
						</li>
					</ul>
				</div>
			</div>
			<div class="creative-center-menu">
				<ul>
					<%var menu=[
						{link:'javascript:',name:'发布文章'},
						{link:'./publishvideo.html',name:'发布短视频'},
						{link:'./publishwtt.html',name:'发布微头条'},
					]%>
					<%menu.forEach(function(item){%>
					<li>
						<a href="<%=item.link%>">
							<i></i>
							<p><%=item.name%></p>
						</a>
					</li>
					<%})%>
				</ul>
			</div>
			<div class="creative-menu">
				<div class="inner">
					<div class="menu-top">
						<div class="menu-in">
							<button class="active">全部</button>
						<button>文章</button>
						<button>视频</button>
						<button>微头条</button>
						</div>
					</div>
					<div class="menu-bottom">
						<div class="menu-in">
							<button class="active">全部</button>
							<button>已发布</button>
							<button>审核中</button>
							<button>未通过</button>
						</div>
					</div>
				</div>
			</div>
			<div class="creative-list">
				<!-- wtt 微头条-->
				<!-- sp  视频-->
				<!-- wz  文章-->
				<ul>
					<!-- share 分享-->
					<!-- top 置顶-->
					<!-- del 删除-->
					<!-- modify 修改-->
					<!-- nomodify 禁止修改-->
					<% var list=[
						{
							title:'北京致知学校开放日｜本周末走致知，听鉴教育',
							img:'https://picsum.photos/id/889/253/150',
							type:'wtt',
							time:'2020-3-9',
							id:0,
							pl:10,
							modify:false,
							link:'./wdetail.html'
						},
						{
							title:'北京致知学校开放日｜本周末走致知，听鉴教育',
							img:'https://picsum.photos/id/889/253/150',
							type:'sp',
							time:'2020-3-9',
							id:1,
							pl:10,
							modify:true,
							link:'javascript:',
							duration:'00:30'
						},
						{
							title:'北京致知学校开放日｜本周末走致知，听鉴教育',
							img:'https://picsum.photos/id/889/253/150',
							type:'wz',
							time:'2020-3-9',
							id:1,
							pl:10,
							modify:true,
							link:'javascript:'
						},
						{
							title:'北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育北京致知学校开放日｜本周末走致知，听鉴教育',
							img:'',
							type:'wz',
							time:'2020-3-9',
							id:1,
							pl:10,
							modify:true,
							link:'javascript:'
						}
					]%>
					<% list.forEach(function(lis){%>
					<li class="<%=lis.type%>">
						<div class="lis">
							<%if(lis.img){%>
							<a href="<%=lis.link%>">
								<div <%=lis.duration?('duration='+lis.duration):''%> class="image" style="background-image: url(<%=lis.img%>);"></div>
							</a>
							<%}%>
							<div class="text">
								<a href="<%=lis.link%>">
									<h3><%=lis.title%></h3>
								</a>
								<p>
									<span>已发布 <%=lis.time%></span>
									<span class="operation"></span>
								</p>
							</div>
						</div>
						<div class="tool">
							<a href="<%=lis.link%>"><%=lis.pl%> 评论</a>
							<a class="share"><i></i>分享</a>
							<a class="top"><i></i>置顶</a>
							<a class="del"><i></i>删除</a>
							<a class="<%=lis.modify?'modify':'nomodify'%>"><i></i>修改</a>
						</div>
					</li>
					<%})%>
				</ul>
			</div>
		</section>
		<%= require('@layouts/loginjs.ejs')()%>
	</body>
</html>
